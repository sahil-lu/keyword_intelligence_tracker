PORT=4000

# Copy this file to server/.env and fill in values.
#
# Firebase Admin SDK (required for creating projects & reports — NOT the web apiKey)
# Download a service account JSON from Firebase Console → Project settings → Service accounts.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# Or point to a file:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json

FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# OpenAI — required only for POST /projects/:id/run (AI analysis), not for creating projects
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Search: default mock SERP. Set USE_MOCK_SEARCH=false and add Tavily key for real results.
USE_MOCK_SEARCH=true
TAVILY_API_KEY=tvly-...

# Cron (optional)
ENABLE_SCHEDULER=false

# Browser clients (optional; defaults allow localhost:3000)
# CORS_ORIGIN=http://localhost:3000
