PORT=4000

# Copy this file to server/.env and fill in values.
#
# Firebase Admin SDK (required for creating projects & reports — NOT the web apiKey)
# Download a service account JSON from Firebase Console → Project settings → Service accounts.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# Or point to a file:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json

FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# OpenAI — required for AI analysis
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Search Sources ──────────────────────────────────────────────────
# Set USE_MOCK_SEARCH=false to use real search APIs
USE_MOCK_SEARCH=true

# Tavily — primary web search (required for real search)
TAVILY_API_KEY=tvly-...

# Exa — semantic search (optional, adds extra results)
# EXA_API_KEY=exa-...

# Firecrawl — content extraction (optional, falls back to cheerio)
# FIRECRAWL_API_KEY=fc-...

# ── Email Reports ──────────────────────────────────────────────────
# Provider: "smtp" (default) or "resend"
# EMAIL_PROVIDER=smtp
# EMAIL_API_KEY=your-email-api-key-or-smtp-password
# EMAIL_FROM=noreply@yourdomain.com

# For SMTP provider only:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com

# Dashboard URL for email links
# DASHBOARD_URL=https://your-app.vercel.app

# ── Scheduler ──────────────────────────────────────────────────────
# Set to true to enable daily/weekly cron jobs
ENABLE_SCHEDULER=false

# ── CORS ──────────────────────────────────────────────────────────
# CORS_ORIGIN=http://localhost:3000
